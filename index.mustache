  <section id="contact">
    <div class="container">
      <h1>Contact</h1>
      <p class="lead">
        I'd <strong>love</strong> to chat.
        I'm looking for <strong>hard problems</strong>, <strong>high stakes</strong>, and people who <strong>ship</strong>.
        <br>
        <br>
        Let's build something that matters.
      </p>
      <p>
        <a class="button" href="mailto:me@levithomason.com">
          <i class="fa fa-envelope"></i>
          me@levithomason.com
        </a>
        <a class="button" href="https://linkedin.com/in/levithomason">
          <i class="fa fa-linkedin-square"></i>
          LinkedIn
        </a>
        <a class="button" href="https://github.com/levithomason">
          <i class="fa fa-github"></i>
          GitHub
        </a>
      </p>
    </div>
